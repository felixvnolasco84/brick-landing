# Clave secreta creada en https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx

# Debe pertenecer a un dominio verificado en Resend.
RESEND_FROM_EMAIL=Brick <notificaciones@brickcontrol.mx>

# Recibe cada nueva solicitud y queda como Reply-To de la confirmación.
CONTACT_TO_EMAIL=hola@brickcontrol.mx

# URL pública usada en los enlaces de los correos.
PUBLIC_SITE_URL=https://brickcontrol.mx
VITE_SITE_URL=https://brickcontrol.mx

# Stripe Checkout alojado. Empieza con claves de prueba y cambia a producción
# únicamente después de verificar Checkout y webhooks de punta a punta.
# Esta clave es exclusiva del servidor: nunca uses el prefijo VITE_ aquí.
STRIPE_SECRET_KEY=sk_test_xxxxxxxxx

# Se obtiene al crear el endpoint /api/stripe/webhook en Stripe Workbench.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxx

# IDs de precios recurrentes configurados en Stripe.
STRIPE_PRICE_STARTER=price_1Tvpa9Qc8ijucmCQfo7IgKFy
STRIPE_PRICE_GROWTH=price_1TvpaWQc8ijucmCQXkXZbr0d
STRIPE_PRICE_SCALE=price_1TvpapQc8ijucmCQbw6732qN

# Cambia a true si tus cupones de Stripe deben aceptarse en Checkout.
STRIPE_ALLOW_PROMOTION_CODES=false
