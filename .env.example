# Clave secreta creada en https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx

# Debe pertenecer a un dominio verificado en Resend.
RESEND_FROM_EMAIL=Brick <notificaciones@brickcontrol.mx>

# Recibe cada nueva solicitud y queda como Reply-To de la confirmación.
CONTACT_TO_EMAIL=hola@brickcontrol.mx

# URL pública usada en los enlaces de los correos.
PUBLIC_SITE_URL=https://brickcontrol.mx
VITE_SITE_URL=https://brickcontrol.mx
